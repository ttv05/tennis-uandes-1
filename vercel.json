{
  "buildCommand": "pnpm build:web",
  "outputDirectory": ".web",
  "framework": "expo",
  "installCommand": "pnpm install",
  "env": {
    "EXPO_USE_METRO_WORKSPACE_ROOT": "1",
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ]
}
